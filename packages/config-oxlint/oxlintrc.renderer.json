{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "extends": [
    "./oxlintrc.base.json"
  ],
  "env": {
    "es2022": true,
    "browser": true,
    "node": false
  },
  "rules": {
    "import/no-unassigned-import": "off",
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": [
              "@firebase-desk/repo-firebase",
              "@firebase-desk/repo-firebase/*",
              "@firebase-desk/script-runner",
              "@firebase-desk/script-runner/*"
            ],
            "message": "Renderer may import @firebase-desk/design-tokens and @firebase-desk/product-ui; main-process packages stay blocked."
          },
          {
            "group": [
              "@firebase-desk/*/src/*"
            ],
            "message": "Use package root exports; @firebase-desk/design-tokens and @firebase-desk/product-ui are allowed through their package entrypoints."
          },
          "node:*",
          "electron",
          "fs",
          "path",
          "child_process"
        ]
      }
    ]
  }
}
