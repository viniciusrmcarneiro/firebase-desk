{
  "name": "firebase-desk",
  "version": "0.0.0",
  "private": true,
  "description": "Firebase Desk monorepo root.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.33.2"
  },
  "scripts": {
    "lint": "turbo run lint",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "coverage:summary": "node scripts/coverage-summary.mjs",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "icons:generate": "node scripts/generate-icons.mjs",
    "package:checksums": "node scripts/write-package-checksums.mjs",
    "package:linux:docker": "docker build --platform linux/amd64 -f docker/linux-package.Dockerfile -t firebase-desk-linux-package . && docker run --rm --platform linux/amd64 --cap-add=SYS_ADMIN firebase-desk-linux-package",
    "storybook": "pnpm --filter @firebase-desk/storybook dev",
    "test:e2e": "pnpm --filter @firebase-desk/e2e test:e2e",
    "package": "pnpm --filter @firebase-desk/desktop package"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.5",
    "dprint": "0.54.0",
    "oxlint": "1.61.0",
    "turbo": "2.9.6",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "overrides": {
      "dompurify": "3.4.1",
      "retry-request": "8.0.2",
      "teeny-request": "10.1.2",
      "uuid": "14.0.0"
    },
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "dprint",
      "@firebase/util",
      "protobufjs"
    ]
  }
}
