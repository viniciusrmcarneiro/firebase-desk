{
  "name": "firebase-desk",
  "version": "0.0.0",
  "private": true,
  "description": "Firebase Desk monorepo root.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.33.2"
  },
  "scripts": {
    "lint": "turbo run lint",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "typecheck": "turbo run typecheck typecheck:scripts",
    "typecheck:scripts": "tsc -p scripts/tsconfig.json",
    "test": "turbo run test test:repo-invariants",
    "test:boundaries": "tsx scripts/check-package-boundaries.ts",
    "test:desktop-packaging": "tsx scripts/check-desktop-packaging-contract.ts",
    "test:release-version": "tsx scripts/check-release-version.ts",
    "test:repo-invariants": "pnpm test:boundaries && pnpm test:desktop-packaging && pnpm test:release-version",
    "test:coverage": "turbo run test:coverage test:repo-invariants",
    "test:packaged": "pnpm --dir e2e test:packaged",
    "coverage:summary": "node scripts/coverage-summary.mjs",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "icons:generate": "node scripts/generate-icons.mjs",
    "package:checksums": "node scripts/write-package-checksums.mjs",
    "package:smoke": "turbo run package:smoke:root",
    "package:smoke:root": "pnpm test:packaged",
    "package:linux:docker": "docker build --platform linux/amd64 -f docker/linux-package.Dockerfile -t firebase-desk-linux-package . && docker run --rm --platform linux/amd64 --cap-add=SYS_ADMIN firebase-desk-linux-package",
    "storybook": "pnpm --filter @firebase-desk/storybook dev",
    "test:e2e": "pnpm --dir e2e test:e2e",
    "test:smoke": "pnpm --dir e2e test:withEmulators",
    "package": "pnpm --filter @firebase-desk/desktop package",
    "release:manifest": "tsx scripts/write-release-manifest.ts",
    "package-managers:manifests": "tsx scripts/write-package-manager-manifests.ts"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.5",
    "dprint": "0.54.0",
    "oxlint": "1.61.0",
    "tsx": "4.21.0",
    "turbo": "2.9.6",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "overrides": {
      "dompurify": "3.4.1",
      "retry-request": "8.0.2",
      "teeny-request": "10.1.2",
      "uuid": "14.0.0"
    },
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "dprint",
      "@firebase/util",
      "protobufjs"
    ]
  }
}
