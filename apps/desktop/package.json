{
  "name": "@firebase-desk/desktop",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "Firebase Desk Electron application.",
  "type": "module",
  "main": ".build/out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "oxlint --config ../../packages/config-oxlint/oxlintrc.base.json src/main src/preload && oxlint --config ../../packages/config-oxlint/oxlintrc.renderer.json src/renderer",
    "typecheck": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "package": "pnpm run build && electron-builder --config electron-builder.yml"
  },
  "dependencies": {
    "@firebase-desk/data-format": "workspace:*",
    "@firebase-desk/design-tokens": "workspace:*",
    "@firebase-desk/hotkeys": "workspace:*",
    "@firebase-desk/ipc-schemas": "workspace:*",
    "@firebase-desk/product-ui": "workspace:*",
    "@firebase-desk/repo-contracts": "workspace:*",
    "@firebase-desk/repo-mocks": "workspace:*",
    "@firebase-desk/ui": "workspace:*",
    "@tanstack/react-query": "5.90.12",
    "@tanstack/react-store": "0.11.0",
    "lucide-react": "1.11.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@firebase-desk/config-oxlint": "workspace:*",
    "@firebase-desk/config-tsconfig": "workspace:*",
    "@firebase-desk/config-vitest": "workspace:*",
    "@tailwindcss/postcss": "4.2.4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "41.3.0",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "jsdom": "29.0.2",
    "oxlint": "1.61.0",
    "postcss": "8.5.11",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "7.3.2",
    "vite-plugin-monaco-editor": "1.1.0",
    "vitest": "4.1.5"
  }
}
