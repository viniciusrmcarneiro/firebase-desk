{
  "name": "@firebase-desk/desktop",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "description": "Firebase Desk Electron application.",
  "homepage": "https://github.com/viniciusrmcarneiro/firebase-desk",
  "type": "module",
  "main": ".build/out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "oxlint --config ../../packages/config-oxlint/oxlintrc.base.json src/main src/preload && oxlint --config ../../packages/config-oxlint/oxlintrc.renderer.json src/renderer",
    "typecheck": "tsc -p tsconfig.main.typecheck.json && tsc -p tsconfig.preload.typecheck.json && tsc -p tsconfig.renderer.typecheck.json",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "package": "node ../../scripts/package-desktop.mjs"
  },
  "dependencies": {
    "@firebase-desk/data-format": "workspace:*",
    "@firebase-desk/design-tokens": "workspace:*",
    "@firebase-desk/hotkeys": "workspace:*",
    "@firebase-desk/ipc-schemas": "workspace:*",
    "@firebase-desk/product-ui": "workspace:*",
    "@firebase-desk/repo-contracts": "workspace:*",
    "@firebase-desk/repo-firebase": "workspace:*",
    "@firebase-desk/repo-mocks": "workspace:*",
    "@firebase-desk/script-runner": "workspace:*",
    "@firebase-desk/ui": "workspace:*",
    "@tanstack/react-store": "0.11.0",
    "firebase-admin": "13.8.0",
    "lucide-react": "1.14.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@firebase-desk/config-oxlint": "workspace:*",
    "@firebase-desk/config-tsconfig": "workspace:*",
    "@firebase-desk/config-vitest": "workspace:*",
    "@tailwindcss/postcss": "4.2.4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "electron": "41.5.0",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "jsdom": "29.1.1",
    "oxlint": "1.62.0",
    "postcss": "8.5.13",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vite-plugin-monaco-editor": "1.1.0",
    "vitest": "4.1.5"
  }
}
